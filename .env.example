APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
WEB_ORIGIN=http://localhost:5173

DATABASE_URL=postgresql+psycopg://confluence:confluence@localhost:5432/confluence_manager
REDIS_URL=redis://localhost:6379/0

KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_INTERNAL_URL=
KEYCLOAK_REALM=confluence-manager
KEYCLOAK_CLIENT_ID=confluence-manager-web
KEYCLOAK_AUDIENCE=confluence-manager-api

CONFLUENCE_BASE_URL=http://localhost:8090
CONFLUENCE_SPACE_KEY=DOC
CONFLUENCE_PAT=change-me
CONFLUENCE_API_TIMEOUT_SECONDS=30

LLM_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Switch LightRAG to an OpenAI-compatible endpoint by setting:
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=http://host.docker.internal:1234/v1
# OPENAI_API_KEY=not-needed
# LIGHTRAG_LLM_BINDING=openai
# LIGHTRAG_LLM_BINDING_HOST=http://host.docker.internal:1234/v1
# LIGHTRAG_LLM_BINDING_API_KEY=not-needed
# LIGHTRAG_LLM_MODEL=your-chat-model
# LIGHTRAG_EMBEDDING_BINDING=openai
# LIGHTRAG_EMBEDDING_BINDING_HOST=http://host.docker.internal:1234/v1
# LIGHTRAG_EMBEDDING_BINDING_API_KEY=not-needed
# LIGHTRAG_EMBEDDING_MODEL=your-embedding-model
# LIGHTRAG_EMBEDDING_DIM=1536
LIGHTRAG_BASE_URL=http://localhost:9621
LIGHTRAG_API_KEY=
LIGHTRAG_CHAT_HISTORY_TURNS=3
LIGHTRAG_PIPELINE_TIMEOUT_SECONDS=900
LIGHTRAG_LLM_BINDING=ollama
LIGHTRAG_LLM_BINDING_HOST=http://host.docker.internal:11434
LIGHTRAG_LLM_BINDING_API_KEY=
LIGHTRAG_LLM_MODEL=llama3.1
LIGHTRAG_EMBEDDING_BINDING=ollama
LIGHTRAG_EMBEDDING_BINDING_HOST=http://host.docker.internal:11434
LIGHTRAG_EMBEDDING_BINDING_API_KEY=
LIGHTRAG_EMBEDDING_MODEL=nomic-embed-text
LIGHTRAG_EMBEDDING_DIM=768
LIGHTRAG_EMBEDDING_TOKEN_LIMIT=8192

SYNC_CRON=0 2 * * *
